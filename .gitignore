# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# Entornos virtuales
.env
.venv
env/
venv/
ENV/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Datos sensibles / pesados
data/raw/*.csv
data/raw/*.zip
data/raw/*.parquet
# Excepción: permitir archivos de muestra si se agregan explícitamente
!data/raw/.gitkeep
# Excepción: estos son inputs reales del pipeline, necesarios en CI (GitHub Actions)
!data/raw/results.csv
!data/raw/shootouts.csv
!data/raw/former_names.csv
!data/raw/goalscorers.csv

# Modelos serializados (pueden ser grandes)
models/*.pkl
models/*.joblib
!models/.gitkeep

# Processed (regenerable desde el pipeline)
data/processed/*.parquet
data/processed/*.csv
data/processed/*.json
!data/processed/.gitkeep

# IDEs
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Streamlit
.streamlit/secrets.toml

# Pytest
.pytest_cache/
htmlcov/
.coverage

.vercel

# Claude Code (config local por usuario)
.claude/settings.local.json

# Build artifacts frontend
frontend/tsconfig.tsbuildinfo

# Logs (JSONL observability — regenerable, no va en el repo)
logs/*.jsonl
